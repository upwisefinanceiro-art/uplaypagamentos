{
    admin off
    auto_https off
    persist_config off
}

:80 {
    root * /srv
    encode zstd gzip

    handle /healthz {
        respond "ok" 200
    }

    @static path /assets/* *.js *.css *.png *.jpg *.jpeg *.svg *.webp *.woff *.woff2 *.ico
    @spa_html not path /assets/* *.js *.css *.png *.jpg *.jpeg *.svg *.webp *.woff *.woff2 *.ico /app.webmanifest /sw.js /workbox-*.js
    header @static Cache-Control "public, max-age=31536000, immutable"
    header @spa_html Cache-Control "no-cache, no-store, must-revalidate"
    header @spa_html Pragma "no-cache"
    header @spa_html Expires "0"
    header /app.webmanifest Cache-Control "no-cache, no-store, must-revalidate"
    header /sw.js Cache-Control "no-cache, no-store, must-revalidate"

    try_files {path} /index.html
    file_server
}